<Window
    x:Class="EntregaEvaluacion.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Subir Evaluacion a GitHub"
    Width="720"
    Height="760"
    MinWidth="640"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource BgBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- header (titulo + cuenta) -->
            <RowDefinition Height="Auto" />
            <!-- seccion + banner -->
            <RowDefinition Height="Auto" />
            <!-- modo de subida -->
            <RowDefinition Height="Auto" />
            <!-- formulario -->
            <RowDefinition Height="Auto" />
            <!-- botones accion -->
            <RowDefinition Height="*" />
            <!-- log -->
            <RowDefinition Height="Auto" />
            <!-- status -->
        </Grid.RowDefinitions>

        <!-- ===== Header: titulo + panel cuenta ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Evaluacion -&gt; GitHub" Style="{StaticResource TitleText}" />
            </StackPanel>

            <ui:Card Grid.Column="1" Padding="12">
                <StackPanel MinWidth="220">
                    <TextBlock Text="Cuenta de GitHub" Style="{StaticResource MutedText}" FontWeight="SemiBold" />
                    <TextBlock x:Name="SessionUserText" Text="Verificando..." Style="{StaticResource LabelText}" FontWeight="Bold" Margin="0,4,0,0" />
                    <TextBlock x:Name="SessionEmailText" Text="" Style="{StaticResource MutedText}" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button x:Name="LoginButton" Content="Iniciar sesion" Appearance="Primary" Margin="0,0,8,0" Click="LoginButton_Click" />
                        <ui:Button x:Name="LogoutButton" Content="Cerrar sesion" Appearance="Danger" IsEnabled="False" Click="LogoutButton_Click" />
                    </StackPanel>
                    <ui:HyperlinkButton Content="No tienes cuenta? Creala aqui" NavigateUri="https://github.com/signup" Margin="0,4,0,0" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:Card>
        </Grid>

        <!-- ===== Seccion + banner Classroom ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <TextBlock Text="Tu seccion:" Style="{StaticResource LabelText}" FontWeight="Bold" Margin="0,0,8,0" />
            <ComboBox x:Name="SectionCombo" Width="100" SelectionChanged="SectionCombo_SelectionChanged" />
            <ui:HyperlinkButton x:Name="AssignmentsLink" Content="" Visibility="Collapsed" Margin="16,0,0,0" Click="AssignmentsLink_Click" />
        </StackPanel>

        <!-- ===== Modo de subida ===== -->
        <ui:Card Grid.Row="2" Margin="0,0,0,12" Padding="12">
            <StackPanel>
                <TextBlock Text="Modo de subida" Style="{StaticResource MutedText}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="ModoNuevo" Content="Crear repositorio nuevo" IsChecked="True" GroupName="Modo" Margin="0,0,24,0" Checked="ModoNuevo_Checked" />
                    <RadioButton x:Name="ModoExistente" Content="Usar repositorio existente de mi cuenta" GroupName="Modo" Checked="ModoExistente_Checked" />
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <!-- ===== Formulario ===== -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Nombre completo -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre completo:" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
            <ui:TextBox x:Name="NombreBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" TextChanged="NombreBox_TextChanged" />

            <!-- Tipo de evaluacion -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tipo de evaluacion:" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
            <ComboBox x:Name="TipoCombo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" HorizontalAlignment="Stretch" SelectionChanged="TipoCombo_SelectionChanged" />

            <!-- Tu repositorio -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tu repositorio:" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
            <ComboBox x:Name="ReposCombo" Grid.Row="2" Grid.Column="1" Margin="0,0,8,8" IsEnabled="False" HorizontalAlignment="Stretch" SelectionChanged="ReposCombo_SelectionChanged" />
            <ui:Button x:Name="RefreshButton" Grid.Row="2" Grid.Column="2" Content="Refrescar" IsEnabled="False" Margin="0,0,0,8" Click="RefreshButton_Click" />

            <!-- Carpeta del proyecto -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Carpeta del proyecto:" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
            <ui:TextBox x:Name="CarpetaBox" Grid.Row="3" Grid.Column="1" IsReadOnly="True" Margin="0,0,8,8" />
            <ui:Button x:Name="BuscarButton" Grid.Row="3" Grid.Column="2" Content="Buscar..." Margin="0,0,0,8" Click="BuscarButton_Click" />

            <!-- Repo destino (preview) -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Repo destino:" Style="{StaticResource LabelText}" Margin="0,0,0,4" />
            <TextBlock x:Name="RepoDestinoText" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="(rellenar nombre y tipo)" Style="{StaticResource MonoText}" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4" />

            <!-- Nota -->
            <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Text="Los repositorios se crean publicos para que el profesor pueda verlos." Style="{StaticResource MutedText}" FontStyle="Italic" FontSize="12" />
        </Grid>

        <!-- ===== Botones accion ===== -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:Button x:Name="CrearButton" Grid.Column="0" Content="1. Crear Repo" Appearance="Primary" Height="40" HorizontalAlignment="Stretch" Margin="0,0,6,0" IsEnabled="False" Click="CrearButton_Click" />
            <ui:Button x:Name="SubirButton" Grid.Column="1" Content="2. Subir Archivos" Appearance="Success" Height="40" HorizontalAlignment="Stretch" Margin="6,0,0,0" IsEnabled="False" Click="SubirButton_Click" />
        </Grid>

        <!-- ===== Log (consola) ===== -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Salida:" Style="{StaticResource LabelText}" Margin="0,0,0,4" />
            <Border Grid.Row="1" Background="{DynamicResource ConsoleBgBrush}" CornerRadius="6">
                <TextBox
                    x:Name="LogBox"
                    Background="Transparent"
                    Foreground="{DynamicResource ConsoleFgBrush}"
                    FontFamily="{DynamicResource MonoFont}"
                    FontSize="13"
                    BorderThickness="0"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Padding="8" />
            </Border>
        </Grid>

        <!-- ===== Status ===== -->
        <TextBlock x:Name="StatusText" Grid.Row="6" Text="Listo." Style="{StaticResource MutedText}" Margin="0,8,0,0" />
    </Grid>
</Window>
