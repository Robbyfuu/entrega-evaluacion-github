<Window
    x:Class="EntregaEvaluacion.Windows.BlackboardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Entrega en Blackboard (DUOC AVA)"
    Width="1100"
    Height="780"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Toolbar ===== -->
        <Border
            Grid.Row="0"
            Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:Button
                    x:Name="BackButton"
                    Grid.Column="0"
                    Content="Atras"
                    Width="80"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="Back_Click" />

                <ui:Button
                    x:Name="ReloadButton"
                    Grid.Column="1"
                    Content="Recargar"
                    Width="90"
                    Margin="0,0,12,0"
                    Click="Reload_Click" />

                <Border
                    Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="UrlText"
                        Text=""
                        Style="{StaticResource MonoText}"
                        FontSize="12"
                        Foreground="{DynamicResource MutedBrush}"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                </Border>

                <ui:Button
                    x:Name="CloseButton"
                    Grid.Column="3"
                    Content="Cerrar"
                    Appearance="Danger"
                    Width="90"
                    Margin="12,0,0,0"
                    Click="CloseWindow_Click" />
            </Grid>
        </Border>

        <!-- ===== Instrucciones de entrega ===== -->
        <Border
            Grid.Row="1"
            Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,8">
            <TextBlock
                x:Name="HintText"
                TextWrapping="Wrap"
                FontSize="12"
                Foreground="{DynamicResource MutedBrush}"
                Text="Inicia sesion con tu cuenta DUOC, abre la tarea del examen final, pega el enlace (Ctrl+V) y ARRASTRA el archivo entrega-XXX.zip (en la carpeta que se abrio) al area de subida." />
        </Border>

        <!-- ===== WebView2 (con drag-drop de archivos habilitado) ===== -->
        <wv2:WebView2 x:Name="Browser" Grid.Row="2" AllowExternalDrop="True" />
    </Grid>
</Window>
