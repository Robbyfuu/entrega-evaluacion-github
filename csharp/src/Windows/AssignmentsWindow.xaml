<Window
    x:Class="EntregaEvaluacion.Windows.AssignmentsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Tareas de GitHub Classroom"
    Width="620"
    Height="480"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="{DynamicResource SurfaceBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="Tareas asignadas por el profesor"
            Style="{StaticResource H2Text}"
            FontSize="18"
            Margin="0,0,0,8" />

        <TextBlock
            Grid.Row="1"
            Text="Pendiente: presiona 'Aceptar' -> se abre Classroom -> acepta en GitHub. Aceptada: ya tienes el repositorio."
            Style="{StaticResource MutedText}"
            TextWrapping="Wrap"
            Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsHost">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Titulo -->
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Text="{Binding Title}"
                                    Style="{StaticResource LabelText}"
                                    FontWeight="Bold"
                                    VerticalAlignment="Center"
                                    TextWrapping="Wrap" />

                                <!-- Badge de estado -->
                                <Border
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    CornerRadius="10"
                                    Padding="10,3"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Background="{Binding BadgeBrush}">
                                    <TextBlock
                                        Text="{Binding StatusLabel}"
                                        Foreground="White"
                                        FontSize="11"
                                        FontWeight="SemiBold" />
                                </Border>

                                <!-- Boton aceptar (solo pendientes) -->
                                <ui:Button
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Content="Aceptar tarea"
                                    Appearance="Success"
                                    Width="150"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"
                                    Tag="{Binding}"
                                    Click="Accept_Click" />

                                <!-- Link al repo (solo aceptadas) -->
                                <ui:HyperlinkButton
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Content="Abrir mi repositorio"
                                    FontSize="12"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding HasRepoLink, Converter={StaticResource BoolToVis}}"
                                    Tag="{Binding RepoUrl}"
                                    Click="OpenRepo_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <ui:Button
            Grid.Row="3"
            Content="Cerrar"
            Width="120"
            Height="36"
            HorizontalAlignment="Center"
            Margin="0,12,0,0"
            Click="Close_Click" />
    </Grid>
</Window>
