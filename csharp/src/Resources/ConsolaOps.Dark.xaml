<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Override OSCURO de los brushes de ConsolaOps. Mismas keys, valores
         oscuros. Se mergea DESPUES de ConsolaOps.xaml para ganar via
         DynamicResource (los estilos referencian los brushes con DynamicResource,
         asi que el swap es en vivo). -->

    <!-- Superficies -->
    <SolidColorBrush x:Key="BgBrush" Color="#0F1115" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#181B21" />
    <SolidColorBrush x:Key="Surface2Brush" Color="#21252D" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2C313A" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#3A4049" />

    <!-- Texto -->
    <SolidColorBrush x:Key="TextBrush" Color="#E6E8EC" />
    <SolidColorBrush x:Key="MutedBrush" Color="#9AA3AF" />
    <SolidColorBrush x:Key="FaintBrush" Color="#6B7280" />

    <!-- Acentos (un poco mas claros para contraste sobre oscuro) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="InfoBrush" Color="#A78BFA" />

    <!-- Consola (ya era oscura, se mantiene) -->
    <SolidColorBrush x:Key="ConsoleBgBrush" Color="#0D0E14" />
    <SolidColorBrush x:Key="ConsoleFgBrush" Color="#4ADE80" />
</ResourceDictionary>
