<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         Design System "Consola Ops" (tema claro por defecto).
         Los colores se exponen como SolidColorBrush con x:Key y se
         referencian con {DynamicResource} para poder swappear a dark.
         ============================================================ -->

    <!-- Superficies -->
    <SolidColorBrush x:Key="BgBrush" Color="#F7F8FA" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Surface2Brush" Color="#F0F2F5" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E5EA" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#CBD0D8" />

    <!-- Texto -->
    <SolidColorBrush x:Key="TextBrush" Color="#1A1D23" />
    <SolidColorBrush x:Key="MutedBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="FaintBrush" Color="#9CA3AF" />

    <!-- Semantico -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706" />
    <SolidColorBrush x:Key="InfoBrush" Color="#7C3AED" />

    <!-- Consola (log): siempre oscura, independiente del tema -->
    <SolidColorBrush x:Key="ConsoleBgBrush" Color="#0D0E14" />
    <SolidColorBrush x:Key="ConsoleFgBrush" Color="#4ADE80" />

    <!-- Fuentes -->
    <FontFamily x:Key="UiFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Consolas, Cascadia Code</FontFamily>

    <!-- ============================================================
         Estilos base de la app. WPF-UI ya provee estilos Fluent para
         sus controles ui:*; aca solo ajustamos tipografia/colores
         neutrales que comparten todas las ventanas.
         ============================================================ -->

    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style x:Key="H2Text" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
        <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
    </Style>

    <Style x:Key="MonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
